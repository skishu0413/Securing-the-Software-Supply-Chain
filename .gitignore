# =============================================================================
# Cache — runtime data, rebuilt automatically on each scan
# Subdirectories contain thousands of API response files that are:
#   - Too large for a repo (~MB of JSON)
#   - User/environment specific (expire by TTL)
#   - Rebuilt on first run automatically
# =============================================================================
cache/nvd/
cache/osv/
cache/pkg_metadata/

# Keep learned detection patterns — these represent accumulated knowledge about
# package ecosystems and improve typosquat detection for anyone who clones the repo.
# cache/learned_patterns.json   → tracked
# cache/learning_data.json      → tracked
# cache/popular_packages.json   → tracked

# =============================================================================
# Logs & debug artifacts
# =============================================================================
*.log
debug_*.py

# =============================================================================
# Generated output / report files
# =============================================================================
output.json
report.json
tests/fixtures/output*.json

# =============================================================================
# Large binary files not needed in the repo
# =============================================================================
*.pdf

